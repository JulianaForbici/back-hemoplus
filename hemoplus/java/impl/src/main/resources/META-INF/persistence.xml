        <class>br.com.senior.mydomain.myservice.Hemocentro_EstoquesEntity</class>
        <class>br.com.senior.mydomain.myservice.AgendamentoEntity</class>
        <class>br.com.senior.mydomain.myservice.DoacaoEntity</class>
        <class>br.com.senior.mydomain.myservice.EstoqueEntity</class>
