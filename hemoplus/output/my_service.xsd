<xsd:schema
    xmlns:xsd="http://www.w3.org/2001/XMLSchema"
    xmlns="http://www.senior.com.br/my_domain/my_service"
    targetNamespace="http://www.senior.com.br/my_domain/my_service"
    elementFormDefault="qualified">
    
    <xsd:attribute name="deprecated" type="xsd:string" default=""/>
    <xsd:attribute name="anonymous" type="xsd:boolean" default="false"/>
    
    <xsd:attribute name="i18n" type="xsd:boolean" default="false"/>
    
    <!-- Public types -->
    <xsd:simpleType name="fatorRh">
        <xsd:restriction base="xsd:string">
            <xsd:enumeration value="NEGATIVO"/>
            <xsd:enumeration value="POSITIVO"/>
        </xsd:restriction>
     </xsd:simpleType>
    <xsd:simpleType name="tipoSangue">
        <xsd:restriction base="xsd:string">
            <xsd:enumeration value="A"/>
            <xsd:enumeration value="B"/>
            <xsd:enumeration value="AB"/>
            <xsd:enumeration value="O"/>
        </xsd:restriction>
     </xsd:simpleType>
    <xsd:simpleType name="tipoUsuario">
        <xsd:restriction base="xsd:string">
            <xsd:enumeration value="DOADOR"/>
            <xsd:enumeration value="ADMIN"/>
        </xsd:restriction>
     </xsd:simpleType>
    <xsd:simpleType name="statusAgendamento">
        <xsd:restriction base="xsd:string">
            <xsd:enumeration value="PENDENTE"/>
            <xsd:enumeration value="CONFIRMADO"/>
            <xsd:enumeration value="CANCELADO"/>
            <xsd:enumeration value="COMPARECEU"/>
            <xsd:enumeration value="NAO_COMPARECEU"/>
        </xsd:restriction>
     </xsd:simpleType>
    <xsd:complexType name="retorno">
        <xsd:sequence>
            <xsd:element name="mensagem" type="xsd:string" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="codigo" type="xsd:string" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="contemErro" type="xsd:boolean" minOccurs="0" maxOccurs="1" default="false" readOnly="false">
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="pontoMapa">
        <xsd:sequence>
            <xsd:element name="id" type="xsd:string" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="tipo" type="xsd:string" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="nome" type="xsd:string" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="latitude" type="xsd:double" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="longitude" type="xsd:double" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="dadosMapa">
        <xsd:sequence>
            <xsd:element name="usuario" type="pontoMapa" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <!-- collection wrapper for hemocentros -->
            <xsd:element name="hemocentros" minOccurs="1" maxOccurs="1">
                <xsd:complexType>
                    <xsd:sequence>
                        <xsd:element name="item" type="pontoMapa" minOccurs="1" maxOccurs="unbounded"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="dashboardResumoAgendamentos">
        <xsd:sequence>
            <xsd:element name="total" type="xsd:long" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="pendentes" type="xsd:long" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="confirmados" type="xsd:long" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="cancelados" type="xsd:long" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="compareceu" type="xsd:long" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="naoCompareceu" type="xsd:long" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="taxaComparecimento" type="xsd:double" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="dashboardSerieDia">
        <xsd:sequence>
            <xsd:element name="dia" type="xsd:date" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="total" type="xsd:long" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="confirmados" type="xsd:long" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="cancelados" type="xsd:long" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="compareceu" type="xsd:long" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="naoCompareceu" type="xsd:long" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="usuario">
        <xsd:sequence>
            <xsd:element name="id" type="xsd:uuid" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="nomeCompleto"  minOccurs="1" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="80" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="email"  minOccurs="1" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="120" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="telefone"  minOccurs="1" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="20" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="cpf"  minOccurs="1" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="11" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="dataNascimento" type="xsd:date" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="ativo" type="xsd:boolean" minOccurs="0" maxOccurs="1" default="true" readOnly="false">
            </xsd:element>
            <xsd:element name="dataCadastro" type="xsd:dateTime" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <!-- collection wrapper for agendamentos -->
            <xsd:element name="agendamentos" minOccurs="0" maxOccurs="1">
                <xsd:complexType>
                    <xsd:sequence>
                        <xsd:element name="item" type="agendamento" minOccurs="0" maxOccurs="unbounded"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
            <!-- collection wrapper for doacoes -->
            <xsd:element name="doacoes" minOccurs="0" maxOccurs="1">
                <xsd:complexType>
                    <xsd:sequence>
                        <xsd:element name="item" type="doacao" minOccurs="0" maxOccurs="unbounded"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
            <xsd:element name="tipoSangue" type="tipoSangue" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="fatorRh" type="fatorRh" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="latitude" type="xsd:double" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="longitude" type="xsd:double" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="usuarioCloud"  minOccurs="1" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="120" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="tipoUsuario" type="tipoUsuario" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="cep"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="9" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="rua"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="80" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="numero"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="10" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="complemento"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="60" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="bairro"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="40" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="cidade"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="40" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="uf"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="2" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="hemocentro">
        <xsd:sequence>
            <xsd:element name="id" type="xsd:uuid" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="nome"  minOccurs="1" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="60" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="rua"  minOccurs="1" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="60" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="numero"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="10" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="bairro"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="40" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="cidade"  minOccurs="1" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="40" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="uf"  minOccurs="1" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="2" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="cep"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="9" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="latitude" type="xsd:double" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="longitude" type="xsd:double" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="telefone"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="20" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="ativo" type="xsd:boolean" minOccurs="0" maxOccurs="1" default="true" readOnly="false">
            </xsd:element>
            <!-- collection wrapper for agendamentos -->
            <xsd:element name="agendamentos" minOccurs="0" maxOccurs="1">
                <xsd:complexType>
                    <xsd:sequence>
                        <xsd:element name="item" type="agendamento" minOccurs="0" maxOccurs="unbounded"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
            <!-- collection wrapper for doacoes -->
            <xsd:element name="doacoes" minOccurs="0" maxOccurs="1">
                <xsd:complexType>
                    <xsd:sequence>
                        <xsd:element name="item" type="doacao" minOccurs="0" maxOccurs="unbounded"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
            <!-- collection wrapper for estoques -->
            <xsd:element name="estoques" minOccurs="0" maxOccurs="1">
                <xsd:complexType>
                    <xsd:sequence>
                        <xsd:element name="item" type="estoque" minOccurs="0" maxOccurs="unbounded"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="agendamento">
        <xsd:sequence>
            <xsd:element name="id" type="xsd:uuid" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="dataHora" type="xsd:dateTime" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="status" type="statusAgendamento" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="observacao"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="150" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="motivoStatus"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="150" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="dataCriacao" type="xsd:dateTime" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="dataAtualizacao" type="xsd:dateTime" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="token"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="80" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="tokenExpiraEm" type="xsd:dateTime" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="tokenUsadoEm" type="xsd:dateTime" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="usuario" type="usuario" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="hemocentro" type="hemocentro" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <!-- collection wrapper for doacoes -->
            <xsd:element name="doacoes" minOccurs="0" maxOccurs="1">
                <xsd:complexType>
                    <xsd:sequence>
                        <xsd:element name="item" type="doacao" minOccurs="0" maxOccurs="unbounded"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="doacao">
        <xsd:sequence>
            <xsd:element name="id" type="xsd:uuid" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="dataHoraConfirmacao" type="xsd:dateTime" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="responsavelValidacao"  minOccurs="0" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:string">
            		<xsd:maxLength value="55" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="usuario" type="usuario" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="hemocentro" type="hemocentro" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="agendamento" type="agendamento" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="tipoSangue" type="tipoSangue" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="fatorRh" type="fatorRh" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="estoque">
        <xsd:sequence>
            <xsd:element name="id" type="xsd:uuid" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="tipoSangue" type="tipoSangue" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="fatorRh" type="fatorRh" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="quantidadeMl"  minOccurs="1" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:long">
            		<xsd:minInclusive value="0" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="minimoMl"  minOccurs="1" maxOccurs="1"  readOnly="false">
            <xsd:simpleType>
            	<xsd:restriction base="xsd:long">
            		<xsd:minInclusive value="0" />
            	</xsd:restriction>
            </xsd:simpleType>
            </xsd:element>
            <xsd:element name="dataAtualizacao" type="xsd:dateTime" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="hemocentro" type="hemocentro" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:simpleType name="userNotificationKind">
        <xsd:restriction base="xsd:string">
            <xsd:enumeration value="Operational"/>
            <xsd:enumeration value="Management"/>
            <xsd:enumeration value="News"/>
        </xsd:restriction>
     </xsd:simpleType>
    <xsd:simpleType name="userNotificationPriority">
        <xsd:restriction base="xsd:string">
            <xsd:enumeration value="Error"/>
            <xsd:enumeration value="Alert"/>
            <xsd:enumeration value="None"/>
        </xsd:restriction>
     </xsd:simpleType>
    <xsd:complexType name="notifyUserEventPayload">
        <xsd:sequence>
            <xsd:element name="notificationClass" type="xsd:string" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="notificationOrigin" type="xsd:string" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="notificationKind" type="userNotificationKind" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="notificationPriority" type="userNotificationPriority" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="notificationSubject" type="xsd:string" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="notificationContent" type="xsd:string" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="sourceDomain" type="xsd:string" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="sourceService" type="xsd:string" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="destinationUser" type="xsd:string" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="link" type="xsd:string" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:simpleType name="eventEmailFormat">
        <xsd:restriction base="xsd:string">
            <xsd:enumeration value="HTML"/>
            <xsd:enumeration value="PLAIN_TEXT"/>
        </xsd:restriction>
     </xsd:simpleType>
    <xsd:complexType name="emailNotifyUserEventPayload">
        <xsd:complexContent>
            <xsd:extension base="notifyUserEventPayload">
                <xsd:sequence>
                    <xsd:element name="from" type="xsd:string" minOccurs="1" maxOccurs="1"  readOnly="false">
                    </xsd:element>
                    <!-- collection wrapper for sendTo -->
                    <xsd:element name="sendTo" minOccurs="0" maxOccurs="1">
                        <xsd:complexType>
                            <xsd:sequence>
                                <xsd:element name="item" type="xsd:string" minOccurs="0" maxOccurs="unbounded"/>
                            </xsd:sequence>
                        </xsd:complexType>
                    </xsd:element>
                    <xsd:element name="format" type="eventEmailFormat" minOccurs="0" maxOccurs="1"  readOnly="false">
                    </xsd:element>
                </xsd:sequence>
            </xsd:extension>
        </xsd:complexContent>
    </xsd:complexType>
    <xsd:complexType name="pushNotifyUserEventPayload">
        <xsd:complexContent>
            <xsd:extension base="notifyUserEventPayload">
                <xsd:sequence>
                    <xsd:element name="applicationId" type="xsd:string" minOccurs="1" maxOccurs="1"  readOnly="false">
                    </xsd:element>
                </xsd:sequence>
            </xsd:extension>
        </xsd:complexContent>
    </xsd:complexType>
    <xsd:complexType name="blobReference">
        <xsd:sequence>
            <xsd:element name="domainName" type="xsd:string" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="serviceName" type="xsd:string" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="targetObjectId" type="xsd:string" minOccurs="1" maxOccurs="1"  readOnly="false">
            </xsd:element>
            <xsd:element name="targetCopyId" type="xsd:string" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    <xsd:complexType name="basicErrorPayload">
        <xsd:sequence>
            <xsd:element name="message" type="xsd:string" minOccurs="0" maxOccurs="1"  readOnly="false">
            </xsd:element>
